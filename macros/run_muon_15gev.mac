/control/verbose 1
/run/verbose 0
/event/verbose 0
/tracking/verbose 0
/process/em/verbose 0

/muonActiveTarget/outputBaseName output/muon_15gev
/run/initialize

# M3-like smoke-test energy.
/gun/particle mu-
/gun/energy 15 GeV
/gun/position 0.1 0.1 -250 mm
/gun/direction 0 0 1

/run/printProgress 100
/run/beamOn 1000
