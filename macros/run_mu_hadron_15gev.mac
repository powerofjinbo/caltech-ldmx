/control/verbose 1
/run/verbose 0
/event/verbose 0
/tracking/verbose 0
/process/em/verbose 0

/muonActiveTarget/outputBaseName output/mu_neutron_15gev_40layer
/run/initialize

# Controlled topology sample: primary mu- plus one injected hadron.
# Change hadronSpecies to pi+, pi-, proton, or neutron for other probes.
/muonActiveTarget/generator/generatorMode muHadron
/muonActiveTarget/generator/hadronSpecies neutron
/muonActiveTarget/generator/secondaryEnergy 1 GeV
/muonActiveTarget/generator/secondaryAngle 10 deg
/muonActiveTarget/generator/emissionLayer 20

/gun/particle mu-
/gun/energy 15 GeV
/gun/position 0.1 0.1 -250 mm
/gun/direction 0 0 1

/run/printProgress 10
/run/beamOn 100
